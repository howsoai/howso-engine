(seq
	(assign_to_entities (load "unit_test.amlg"))
	(call (load "unit_test_howso.amlg") (assoc name "ut_h_signal_preservation.amlg" debug .false retries 0))

	(declare (assoc
		csv_data (load "unit_test_data/adult.csv")
	))

	(declare (assoc
		data (tail csv_data)
		features (first csv_data)
		result .null
		result_features .null
	))

	(call_entity "howso" "set_feature_attributes" (assoc
		feature_attributes
			(assoc
				"age" (assoc "type" "continuous")
				"fnlwgt"  (assoc "type" "continuous")
				"education" (assoc "type" "ordinal" "data_type" "number")
				"education-num"  (assoc "type" "continuous")
				"marital-status" (assoc "type" "nominal" "data_type" "number")
				"occupation" (assoc "type" "nominal" "data_type" "number")
				"relationship" (assoc "type" "nominal" "data_type" "number")
				"race"  (assoc "type" "nominal" "data_type" "number")
				"sex" (assoc "type" "nominal" "data_type" "number")
				"capital-gain" (assoc "type" "continuous")
				"capital-loss" (assoc "type" "continuous")
				"hours-per-week" (assoc "type" "continuous")
				"native-country" (assoc "type" "nominal" "data_type" "number")
				"target" (assoc "type" "nominal" "data_type" "number")
				"workclass"
					(assoc
						"type" "nominal"
						"data_type" "number"
						;configuring the signal preservation attributes.
						;These must be computed above the engine layer, and were so for this test.
						"signal_preservation"
							{
								"protected_values" [
									{"multiplier" 4 "value" 8}
                                    {"multiplier" 8 "value" 3}
								]
               					"unprotected_multiplier" 0.997275204359673
							}
					)
			)
	))

	(call_entity "howso" "train" (assoc
		cases data
		features features
		session "session"
	))

	(assign (assoc
		result
			(call_entity "howso" "get_cases" (assoc
				features [".case_weight" "workclass"]
				condition {"workclass" 3}
				num_cases 3
			))
	))
	(call keep_result_payload)

	(print "Cases with workclass=3 all have a weight of 8: ")
	(call assert_true (assoc
		obs (apply "=" (append (map (lambda (first (current_value))) (get result "cases")) 8 ) )
	))

	(assign (assoc
		result
			(call_entity "howso" "get_cases" (assoc
				features [".case_weight" "workclass"]
				condition {"workclass" 8}
				num_cases 3
			))
	))
	(call keep_result_payload)

	(print "Cases with workclass=8 all have a weight of 4: ")
	(call assert_true (assoc
		obs (apply "=" (append (map (lambda (first (current_value))) (get result "cases")) 4 ) )
	))

	(assign (assoc
		result
			(call_entity "howso" "get_cases" (assoc
				features [".case_weight" "workclass"]
				condition {"workclass" 6}
				num_cases 3
			))
	))
	(call keep_result_payload)

	(print "Cases with an unprotected workclass all have values less than 1: ")
	(call assert_approximate (assoc
		obs (get result ["cases" 0 0])
		exp 0.997275204359673 ;unprotected_multiplier configured above in feature attributes
		percent 0.001
	))


	(assign (assoc
		result
			(call_entity "howso" "get_value_masses" (assoc
				features ["workclass"]
				weight_feature ".case_weight"
			))
	))
	(call keep_result_payload)

	(print "Total mass after weight adjustments still approximately matches total data: ")
	(call assert_approximate (assoc
		exp (size data)
		obs (apply "+" (map (lambda (last (current_value))) (get result ["masses" "workclass" "values"])))
		percent 0.001
	))

	(print "workclass=8 has mass of 4 times its original frequency (21): ")
	(call assert_approximate (assoc
		exp (* 4 21)
		obs (get (filter (lambda (= 8 (first (current_value)))) (get result ["masses" "workclass" "values"])) [0 1])
		percent 0.001
	))

	(print "workclass=3 has mass of 8 times its original frequency (10): ")
	(call assert_approximate (assoc
		exp (* 8 10)
		obs (get (filter (lambda (= 3 (first (current_value)))) (get result ["masses" "workclass" "values"])) [0 1])
		percent 0.001
	))

	(call exit_if_failures (assoc msg unit_test_name))
)