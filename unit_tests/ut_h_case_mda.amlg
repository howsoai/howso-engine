(seq

	;import the unit_test 'library'
	(assign_to_entities (load "unit_test.amlg"))
	(call (load "unit_test_howso.amlg") (assoc name "ut_h_case_mda.amlg" retries 1))

	(call_entity "howso" "set_feature_attributes" (assoc
		feature_attributes (assoc "target" (assoc "type" "nominal" "data_type" "number") )
	))

	(declare (assoc
		data (load "unit_test_data/iris.csv")
	))

	(declare (assoc
		features (first data)
		train_data (tail data)
		result .null
	))

	(call_entity "howso" "set_params" (assoc
		default_hyperparameter_map (assoc "k" 4 "p" 2 "dt" -1)
	))

	(call_entity "howso" "train" (assoc
		features features
		cases train_data
		session "default"
	))

	(assign (assoc
		result
			(call_entity "howso" "single_react" (assoc
				context_features (list "sepal_length" "petal_length" "petal_width" "target")
				context_values (list 6.4 5.6 2.0 2)

				action_features (list "sepal_width")
				details (assoc "case_full_accuracy_contributions" .true)
			))
	))
	(print "standard continuous case mda: ")
	(call assert_approximate (assoc
		obs (get result (list 1 "payload" "case_full_accuracy_contributions"))
		exp
			(list
				(assoc ".session" "default" ".session_training_index" 106 "accuracy_contribution" [0.058 .null .null])
				(assoc ".session" "default" ".session_training_index" 93 "accuracy_contribution" [0.072 .null .null])
				(assoc ".session" "default" ".session_training_index" 32 "accuracy_contribution" [0.016 .null .null])
				(assoc ".session" "default" ".session_training_index" 18 "accuracy_contribution" [0.02 .null .null])
			)
		thresh .03
	))

	(assign (assoc
		result
			(call_entity "howso" "single_react" (assoc
				context_features (list "sepal_length" "petal_length" "petal_width" "target")
				context_values (list 6.4 5.6 2.0 2)

				action_features (list "sepal_width")
				details (assoc "case_robust_accuracy_contributions" .true )
			))
	))
	(print "robust continuous case mda: ")
	(call assert_approximate (assoc
		obs (get result (list 1 "payload" "case_robust_accuracy_contributions"))
		exp
			(list
				(assoc ".session" "default" ".session_training_index" 106 "accuracy_contribution" [0.058 .null .null])
				(assoc ".session" "default" ".session_training_index" 93 "accuracy_contribution" [0.07 .null .null])
				(assoc ".session" "default" ".session_training_index" 32 "accuracy_contribution" [0.02 .null .null])
				(assoc ".session" "default" ".session_training_index" 18 "accuracy_contribution" [0.02 .null .null])
			)
		thresh 0.03
	))


	(assign (assoc
		result
			(call_entity "howso" "single_react" (assoc
				context_features (list "sepal_length" "petal_length" "petal_width" "sepal_width")
				context_values (list 6.7 5.0 1.7 2.8)

				action_features (list "target")
				details (assoc "case_full_accuracy_contributions" .true)
			))
	))
	(print "standard nominal case mda: ")
	(call assert_approximate (assoc
		obs (get result (list 1 "payload" "case_full_accuracy_contributions"))
		exp
			(list
				(assoc ".session" "default" ".session_training_index" 144 "accuracy_contribution" [0 .null .null])
				(assoc ".session" "default" ".session_training_index" 142 "accuracy_contribution" [0.04 .null .null])
				(assoc ".session" "default" ".session_training_index" 22 "accuracy_contribution" [0.05 .null .null])
				(assoc ".session" "default" ".session_training_index" 47 "accuracy_contribution" [0.00 .null .null])
			)
		thresh 0.08
	))

	(assign (assoc
		result
			(call_entity "howso" "single_react" (assoc
				context_features (list "sepal_length" "petal_length" "petal_width" "sepal_width")
				context_values (list 6.7 5.0 1.7 2.8)

				action_features (list "target")
				details (assoc "case_robust_accuracy_contributions" .true)
			))
	))
	(print "robust nominal case mda: ")
	(call assert_approximate (assoc
		obs (get result (list 1 "payload" "case_robust_accuracy_contributions"))
		exp
			(list
				(assoc ".session" "default" ".session_training_index" 144 "accuracy_contribution" [0 .null .null])
				(assoc ".session" "default" ".session_training_index" 142 "accuracy_contribution" [0.04 .null .null])
				(assoc ".session" "default" ".session_training_index" 22 "accuracy_contribution" [0.065 .null .null])
				(assoc ".session" "default" ".session_training_index" 47 "accuracy_contribution" [0 .null .null])
			)
		thresh 0.04
	))

	(call exit_if_failures (assoc msg unit_test_name ))
)
