(seq
	(assign_to_entities (load "unit_test.amlg"))
	(call (load "unit_test_howso.amlg") (assoc name "ut_h_density_conviction.amlg" ))

	(declare (assoc
		features ["x" "y" "color" ]
		result .null
		data
			[
				;group 1
				[ 100 	100 	"blue" ] ; 0
				[ 101 	100 	"blue" ]
				[ 100 	110 	"blue" ]
				[ 101 	110 	"blue" ]
				[ 102 	100 	"blue" ]
				[ 102 	110 	"blue" ] ; 5
				;group 2
				[ 100 	300 	"blue" ]
				[ 101 	300 	"blue" ]
				[ 100 	310 	"blue" ]
				[ 101 	310 	"blue" ]
				[ 102 	300 	"blue" ] ; 10
				[ 102 	310 	"blue" ]
				;case between group1 and 2
				[ 100 	200 	"blue" ] ; 12 - bimodal on 'y'
				;case outside group 1
				[ 100 	80 		"blue" ] ; 13
				;group 3
				[ 600 	600 	"orange" ]
				[ 601 	601 	"orange" ] ; 15 inlier
				[ 601 	601 	"orange" ]
				[ 601 	601 	"orange" ]
				[ 601 	601 	"orange" ]
				[ 602 	600 	"orange" ]

				;group 3 with continous nulls
				[ 600 	.null 	"green" ] ; 20
				[ 300 	400 	"green" ]
				[ 300 	.null	"green" ] ; null case
				[ 301 	400 	"green" ]
				[ 600 	.null 	"green" ]
				[ 500 	400 	"green" ] ; 25
				[ 501 	400 	"green" ]


				[ 11500 	100 	"yellow" ]
				[ 11501 	200 	"yellow" ]
				[ 11502 	300 	"yellow" ]
				[ 11503 	400 	"yellow" ] ;30
				[ 11504 	500 	"yellow" ]
				[ 11505 	500 	"yellow" ]
			]
	))


	(call_entity "howso" "set_feature_attributes" (assoc
		feature_attributes
			(assoc
				"x" (assoc "type" "continuous")
				"y" (assoc "type" "continuous")
				"color" (assoc "type" "nominal" "data_type" "string")
			)
	))


	(call_entity "howso" "train" (assoc
		cases data
		features features
		session "session1"
	))
	(call_entity "howso" "analyze")

	(assign (assoc
		result
			(call_entity "howso" "single_react" (assoc
				case_indices (list "session1" 12)
				preserve_feature_values features
				leave_case_out .true
				details (assoc feature_density_convictions .true )
			))
	))

	(call keep_result_payload)
	(print "Density conviction is extremely low for bi-modal neighbors: " (get result ["feature_density_convictions" "y"]) " " )
	(call assert_true (assoc
		obs (< (get result ["feature_density_convictions" "y"]) 0.1)
	))

	(print "Density conviction is max for all nominal match: ")
	(call assert_same (assoc
		exp .infinity
		obs (get result ["feature_density_convictions" "color"])
	))


	(assign (assoc
		result
			(call_entity "howso" "single_react" (assoc
				case_indices (list "session1" 13)
				preserve_feature_values features
				leave_case_out .true
				details (assoc feature_density_convictions .true )
			))
	))
	(call keep_result_payload)
	(print "Density conviction is very low for case outside group: " (get result ["feature_density_convictions" "y"]) " ")
	(call assert_approximate (assoc
		obs (get result ["feature_density_convictions" "y"])
		exp 0.2
		thresh 0.1
	))


	(assign (assoc
		result
			(call_entity "howso" "single_react" (assoc
				case_indices (list "session1" 19)
				preserve_feature_values features
				leave_case_out .true
				details (assoc feature_density_convictions .true )
			))
	))
	(call keep_result_payload)
	(print "Density conviction is low for case at edge of group: " (get result ["feature_density_convictions" "y"]) " ")
	(call assert_approximate (assoc
		obs (get result ["feature_density_convictions" "y"])
		exp 0.5
		thresh 0.1
	))


	(assign (assoc
		result
			(call_entity "howso" "single_react" (assoc
				case_indices (list "session1" 7)
				preserve_feature_values features
				leave_case_out .true
				details (assoc feature_density_convictions .true )
			))
	))
	(call keep_result_payload)
	(print "Density conviction is normal for case inside group: " (get result ["feature_density_convictions" "y"]) " ")
	(call assert_approximate (assoc
		obs (get result ["feature_density_convictions" "y"])
		exp 1.0
		thresh 0.2
	))


	(assign (assoc
		result
			(call_entity "howso" "single_react" (assoc
				case_indices (list "session1" 15)
				preserve_feature_values features
				leave_case_out .true
				details (assoc feature_density_convictions .true )
			))
	))
	(call keep_result_payload)
	(print "Density conviction is high for inlier case: " (get result ["feature_density_convictions" "y"]) " ")
	(call assert_approximate (assoc
		obs (get result ["feature_density_convictions" "y"])
		exp 1.6
		thresh 0.2
	))

	(assign (assoc
		result
			(call_entity "howso" "single_react" (assoc
				case_indices (list "session1" 22)
				preserve_feature_values features
				leave_case_out .true
				details (assoc feature_density_convictions .true )
			))
	))
	(call keep_result_payload)
	(print "Density conviction for null is high, nulls are > 60% of influence: " (get result ["feature_density_convictions" "y"]) " ")
	(call assert_approximate (assoc
		obs (get result ["feature_density_convictions" "y"])
		exp 1.7
		thresh 0.3
	))

	(call exit_if_failures (assoc msg "Continuous density convictions."))


	(call_entity "howso" "train" (assoc
		cases
			[
				[ 5000 	2000 	"yellow" ] ;0
				[ 5002 	2000 	"yellow" ]
				[ 5024 	2000 	"yellow" ] ;2

				[ 5050 	2015 	"tan"    ]
				[ 5050 	2015 	"tan" 	 ]
				[ 5052 	2015 	"tan" 	 ]

				[ 5082 	2015	"yellow" ] ;6

			]
		features features
		session "session2"
	))

	(call_entity "howso" "analyze")

	(assign (assoc
		result
			(call_entity "howso" "single_react" (assoc
				case_indices (list "session2" 0)
				preserve_feature_values features
				leave_case_out .true
				details (assoc feature_density_convictions .true )
			))
	))
	(call keep_result_payload)
	(print "Density conviction for nominal is 1 because it's a 'yellow' among 99%+ 'yellow's: ")
	(call assert_approximate (assoc
		obs (get result ["feature_density_convictions" "color"])
		exp 1
		thresh 0.001
	))

	(assign (assoc
		result
			(call_entity "howso" "single_react" (assoc
				case_indices (list "session2" 2)
				preserve_feature_values features
				leave_case_out .true
				details (assoc feature_density_convictions .true)
			))
	))
	(call keep_result_payload)
	(print "Density conviction is high b/c mostly near 'yellow's with a little 'tan': " (get result ["feature_density_convictions" "color"]) " ")
	(call assert_approximate (assoc
		obs (get result ["feature_density_convictions" "color"])
		exp 1.5
		thresh 0.2
	))


	(assign (assoc
		result
			(call_entity "howso" "single_react" (assoc
				case_indices (list "session2" 6)
				preserve_feature_values features
				leave_case_out .true
				details (assoc feature_density_convictions .true )
			))
	))
	(call keep_result_payload)
	(print "Density conviction is low b/c more 'tan' are closer than other 'yellow': " (get result ["feature_density_convictions" "color"]) " ")
	(call assert_approximate (assoc
		obs (get result ["feature_density_convictions" "color"])
		exp .75
		thresh 0.2
	))

	(call exit_if_failures (assoc msg "Nominal density convictions."))

	(call exit_if_failures (assoc msg unit_test_name))
)
