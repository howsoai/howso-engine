(seq
	;import the unit_test 'library'
	#unit_test (direct_assign_to_entities (assoc unit_test (load "unit_test.amlg")))
	(call (load "unit_test_howso.amlg") (assoc name "ut_h_one_value_cont.amlg"))


	(declare (assoc
		;set to true to see full output
		verbose .false
	    data (load "unit_test_data/bool_null_test.csv")
	))

	; DATASET DESCRIPTION
	; This dataset is a simple 4 feature dataset.

	; 'a' is a randomly generated continuous value.
	; 'up_b' is a randomly selected nominal number (effectively a boolean), zero or one. (up_b = boolean describing if value goes up [or down])
	; 'noise' is a randomly generated continuous value, with no relationships to other features.
	; 'target' is a continuous value. When 'up_b' is 1, 'target' is 'a' + 10, otherwise 'target' is 'a' - 10.

	; As a result, we hope to see strong relationships between 'target', 'a', and 'up_b'.

	; In this test, up_b will be treated as continuous and all the values of zero will be replaced with (null)

	(declare (assoc
		features (first data)
		training_data (tail data)
	))

	(call_entity "howso" "set_feature_attributes" (assoc
		feature_attributes
			(assoc
				up_b {"type" "continuous" "data_type" "number" "bounds" {"max" 2 "min" 0}}
				;rest are just continuous values so no need to specify
			)
	))

	(call_entity "howso" "train" (assoc
		features features
		cases
			training_data
			;replacing all zeros in up_b with (null)
			; (map
			; 	(lambda
			; 		;replace 0 with nulls for up_b (second_value)
			; 		(if (= 0 (get (current_value) 1))
			; 			(set (current_value) 1 (null))

			; 			;else
			; 			(current_value)
			; 		)
			; 	)
			; 	training_data
			; )
	))
	(call_entity "howso" "analyze" (assoc convergence_threshold 0))

	(declare (assoc
		pred_stats
			(get
				(call_entity "howso" "react_aggregate" (assoc
					details {"prediction_stats" .true}
				))
				[1 "payload"]
			)
		hyperparams
			(get
				(call_entity "howso" "get_params" (assoc
					action_feature ""
				))
				[1 "payload" "hyperparameter_map"]
			)
	))

	(print "Feature MDA parameters for target: ")
	(call assert_approximate (assoc
		exp
			{
				noise 0
				a 0.5
				up_b 0.5
				target 0
			}
		obs (get hyperparams ["featureMdaMap" "target"])
		thresh 0.05
	))

	(print "Feature MDA parameters for a: ")
	(call assert_approximate (assoc
		exp
			{
				noise 0
				a 0
				up_b 0.5
				target 0.5
			}
		obs (get hyperparams ["featureMdaMap" "a"])
		thresh 0.05
	))

	(print "Target MAE: ")
	(call assert_approximate (assoc
		exp 3.9
		obs (get pred_stats ["mae" "target"])
	))

	(print "a MAE: ")
	(call assert_approximate (assoc
		exp 3.9
		obs (get pred_stats ["mae" "a"])
	))

	(call exit_if_failures (assoc msg unit_test_name))
)
