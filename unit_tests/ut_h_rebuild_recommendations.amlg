(seq
	(assign_to_entities (load "unit_test.amlg"))
	(call (load "unit_test_howso.amlg") (assoc name "ut_h_rebuild_recommendations.amlg"))

	(declare (assoc
		features (list "x" "y" "label")
		result .null
		attributes
			(assoc
				"x" (assoc "type" "continuous")
				"y" (assoc "type" "continuous")
				"label" (assoc "type" "nominal")
			)
	))


	(call_entity "howso" "set_feature_attributes" (assoc
		feature_attributes attributes
	))

	(assign (assoc
		result
			(call_entity "howso" "get_rebuild_recommendation" (assoc
				new_feature_attributes (append attributes {"z" {"type" "nominal"}})
			))
	))
	(call keep_result_payload)

	(print "Rebuild recommended after new features in attributes: ")
	(call assert_same (assoc
		exp .true
		obs (get result "rebuild")
	))

	(call exit_if_failures (assoc msg unit_test_name))
)
