(seq
	(assign_to_entities (load "unit_test.amlg"))
	(call (load "unit_test_howso.amlg") (assoc name "ut_h_value_expression.amlg"))

	(declare (assoc
		iris_data (load "unit_test_data/iris.csv")
	))
	(declare (assoc
		features (first iris_data)
		data (tail iris_data)
		context_features (list "sepal_length" "sepal_width" "petal_length" "petal_width")
		action_features (list "target")
		result .null
	))

	(call_entity "howso" "set_feature_attributes" (assoc
		feature_attributes
			(assoc
				"target" (assoc "type" "nominal" "data_type" "number")
				"sepal_width"
					(assoc
						"type" "continuous"
						"value_evaluation_code" (lambda (call_on_entity .null (pow 2 sepal_width)))
					)
			)
	))

	(call_entity "howso" "train" (assoc
		features features
		cases data
		session "session"
	))

	(assign (assoc
		result
			(call_entity "howso" "react" (assoc
				context_features ["sepal_width"]
				context_values [ [4] ]
				action_features action_features
				details (assoc "influential_cases" .true)
			))
	))
	(call keep_result_payload)

	(print "The found influential case has a sepal_width of 4^(1/2)=2 rather than 4: ")
	(call assert_same (assoc
		exp 2
		obs (get result ["influential_cases" 0 0 "sepal_width"])
	))

	(call exit_if_failures (assoc msg unit_test_name))
)
