(seq

	(declare (assoc
		validate_if_requested
			(lambda (if (contains_value argv "validate")
				(system "validate")
			))
	))

	(declare (assoc ut_comprehensive_start_time (system_time)))

	;run the entire unit test suite

	;basic data set specific tests
	(assign_to_entities (assoc it (load "ut_iris.amlg")))
	(call  it)
	(call validate_if_requested)
	(print "############################################################\n")

	(assign_to_entities (assoc at (load "ut_abalone.amlg")))
	(call  at)
	(call validate_if_requested)
	(print "############################################################\n")

	(assign_to_entities (assoc ug (load "ut_iris_generate_data.amlg")))
	(call  ug)
	(call validate_if_requested)
	(print "############################################################\n")

	;Howso API specific tests
	(assign_to_entities (assoc st (load "ut_howso.amlg")))
	(call  st)
	(print "############################################################\n")

	(print "\nPASSED : Total comprehensive test execution time: " (- (system_time) ut_comprehensive_start_time) " s\n")
)