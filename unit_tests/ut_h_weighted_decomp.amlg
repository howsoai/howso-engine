(seq
	(assign_to_entities (load "unit_test.amlg"))
	(call (load "unit_test_howso.amlg") (assoc name "ut_h_weighted_decomp.amlg" retries 0))

	(declare (assoc
		data (load "unit_test_data/iris.csv")
	))

    (declare (assoc
		features (first data)
		train_data (tail data)
		result .null
	))

	(call_entity "howso" "set_feature_attributes" (assoc
		feature_attributes (assoc "target" (assoc "type" "nominal" "data_type" "number") )
	))

	(call_entity "howso" "train" (assoc
		features features
		cases train_data
	))

	(call_entity "howso" "analyze")


	(call_entity "howso" "set_auto_ablation_params" (assoc
		auto_ablation_enabled .true
		min_num_cases 30
		max_num_cases 30
		reduce_max_cases 30
	))
	(call_entity "howso" "reduce_data")

	(print "Reduces to the 30 cases as expected: ")
	(call assert_same (assoc
		exp 30
		obs (get (call_entity "howso" "get_num_training_cases") [1 "payload" "count"])
	))

	(assign (assoc
		result
			(call_entity "howso" "react_aggregate" (assoc
				details {"value_robust_accuracy_contributions" .true}
				value_robust_contributions_features ["target"]
				value_robust_contributions_action_feature "sepal_length"
			))
	))
	(call keep_result_payload)

	(print "All 3 species are still given buckets after reduction: ")
	(call assert_same (assoc
		exp 3
		obs (size (get result ["value_robust_contributions" "feature_values"]))
	))
	(print result)

	(call exit_if_failures (assoc msg unit_test_name ))
)
